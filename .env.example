# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=development

# ── Database (Supabase PostgreSQL) ───────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/careremind

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# ── Cache & Queue ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Authentication ───────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-minimum-32-chars
JWT_EXPIRY_HOURS=24

# ── Patient Data Encryption ─────────────────────────────────
FIELD_ENCRYPTION_KEY=

# ── AI — Message Generation ─────────────────────────────────
GROQ_API_KEY=
OPENAI_API_KEY=

# ── WhatsApp (Meta Cloud API) ────────────────────────────────
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=

# ── SMS Fallback ─────────────────────────────────────────────
FAST2SMS_API_KEY=

# ── Vision OCR ───────────────────────────────────────────────
VISION_BACKEND=google
GOOGLE_VISION_KEY=

# ── Storage ──────────────────────────────────────────────────
STORAGE_BACKEND=supabase

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# ── Payments (V4) ───────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=

# ── AWS (leave empty until migration) ───────────────────────
AWS_S3_BUCKET=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_TEXTRACT_REGION=

# ── Monitoring ───────────────────────────────────────────────
SENTRY_DSN=
