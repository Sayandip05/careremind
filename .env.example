# ══════════════════════════════════════════════════════════════
# CareRemind - Environment Configuration Template
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# All API keys are optional for demo/portfolio
# ══════════════════════════════════════════════════════════════

# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=development

# ── Database (Supabase PostgreSQL) ───────────────────────────
# Get this from Supabase Dashboard → Project Settings → Database → Connection String
# Format: postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# ── Supabase (Storage & SDK) ─────────────────────────────────
# Get these from Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# ── Cache & Queue ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Authentication ───────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── Social OAuth Logins (Optional) ───────────────────────────
ENABLE_GOOGLE_OAUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

ENABLE_FACEBOOK_OAUTH=false
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=

# ── Patient Data Encryption ──────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required for production - encrypts patient phone numbers
FIELD_ENCRYPTION_KEY=

# ── AI — Message Generation (Optional) ───────────────────────
# Leave empty for demo - reminders will use default templates
GROQ_API_KEY=
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# ── WhatsApp (Meta Cloud API) - Optional ─────────────────────
# Leave empty for demo/portfolio - system will gracefully degrade to SMS
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_WHATSAPP_API_VERSION=v21.0

# ── SMS Fallback (Optional) ──────────────────────────────────
FAST2SMS_API_KEY=
FAST2SMS_API_URL=https://www.fast2sms.com/dev/bulkV2

# ── Vision OCR (Optional) ────────────────────────────────────
# Leave empty for demo - Excel upload will still work
VISION_BACKEND=nvidia
NVIDIA_API_KEY=
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
GOOGLE_VISION_KEY=

# ── Storage ──────────────────────────────────────────────────
STORAGE_BACKEND=supabase

# ── AWS (Optional - leave empty until migration) ─────────────
AWS_S3_BUCKET=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_TEXTRACT_REGION=

# ── Payments (V2 Booking Feature) - Optional ─────────────────
# Leave empty for demo - booking flow will work without actual payment
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_API_URL=https://api.razorpay.com/v1

# ── API URLs ─────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3002

# ── Monitoring (Optional) ────────────────────────────────────
ENABLE_SENTRY=false
SENTRY_DSN=

# ── Background Workers (Optional) ────────────────────────────
# Set to true if using Celery workers for async processing
ENABLE_CELERY=false

# ── Database Pool ────────────────────────────────────────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ══════════════════════════════════════════════════════════════
# Notes:
# - All API keys are optional for demo/portfolio
# - System gracefully handles missing credentials
# - For production, set all required variables
# - See ENV_SETUP_GUIDE.md for detailed setup instructions
# ══════════════════════════════════════════════════════════════
