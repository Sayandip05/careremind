# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=development

# ── Database (Supabase PostgreSQL) ───────────────────────────
# Get this from Supabase Dashboard → Project Settings → Database → Connection String
# Format: postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# ── Supabase ─────────────────────────────────────────────────
# Get these from Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-service-role-key  # Use service_role key (NOT anon/public)

# ── Cache & Queue ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Authentication ───────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-minimum-32-chars
JWT_EXPIRY_HOURS=24

# ── Patient Data Encryption ─────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required for production - encrypts patient phone numbers
FIELD_ENCRYPTION_KEY=

# ── AI — Message Generation ─────────────────────────────────
# Optional - Only needed for AI message generation
# Leave empty for demo - reminders will use default templates
GROQ_API_KEY=
OPENAI_API_KEY=

# ── WhatsApp (Meta Cloud API) ────────────────────────────────
# Optional - Only needed for production with Meta Business verification
# Leave empty for demo/portfolio - system will gracefully degrade to SMS
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=

# ── SMS Fallback ─────────────────────────────────────────────
FAST2SMS_API_KEY=

# ── Vision OCR ───────────────────────────────────────────────
# Optional - Only needed for photo OCR feature
# Leave empty for demo - Excel upload will still work
VISION_BACKEND=nvidia
NVIDIA_API_KEY=

# ── Storage ──────────────────────────────────────────────────
STORAGE_BACKEND=supabase

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# ── Payments (V2 Booking Feature) ───────────────────────────
# Optional - Only needed for V2 booking feature with real payments
# Leave empty for demo - booking flow will work without actual payment
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── AWS (leave empty until migration) ───────────────────────
AWS_S3_BUCKET=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_TEXTRACT_REGION=

# ── Monitoring ───────────────────────────────────────────────
SENTRY_DSN=
